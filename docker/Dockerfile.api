FROM node:20-alpine
WORKDIR /app
RUN apk add --no-cache wget
COPY server/package*.json ./
RUN npm ci --omit=dev
COPY server/ ./
ENV NODE_ENV=production
EXPOSE 5001
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD wget -qO- http://localhost:5001/api/health/ready || exit 1
CMD ["node", "index.js"]
