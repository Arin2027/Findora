# Findora API — production environment template
# Copy values into Render → Environment (or your host's secret manager).
# Do NOT commit real secrets. Run: npm run verify:env

NODE_ENV=production
# Render injects PORT automatically; keep unset or match host default
PORT=10000

# --- MongoDB Atlas (required) ---
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/findora?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/findora?retryWrites=true&w=majority

# --- JWT (required) ---
# Min 32 characters in production. Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS + Socket.IO (required) ---
# Must exactly match your Vercel production URL (no trailing slash)
CLIENT_URL=https://findora.vercel.app
APP_URL=https://findora.vercel.app

# --- OpenAI (required for hybrid/semantic matching) ---
OPENAI_API_KEY=sk-REPLACE
EMBEDDING_MODEL=text-embedding-3-small
AI_MATCHING_MODE=hybrid

# --- Hugging Face (optional — image CLIP matching) ---
HF_API_KEY=hf_REPLACE
HF_CLIP_MODEL=openai/clip-vit-base-patch32
ENABLE_IMAGE_MATCHING=true

# --- Cloudinary (recommended — all three or leave all empty) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Upstash Redis (optional — caching) ---
# Format: rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# --- Email (optional — verification & password reset) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Findora <noreply@findora.app>

# --- Uploads (local fallback when Cloudinary disabled) ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# --- Matching tuning ---
MATCH_THRESHOLD=0.75
MATCH_DEBUG=false
TEXT_MATCH_WEIGHT=0.4
IMAGE_MATCH_WEIGHT=0.4
LOCATION_MATCH_WEIGHT=0.2
LOCATION_MAX_KM=25
