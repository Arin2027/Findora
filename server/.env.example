NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/findora
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:5173

# Production template: see .env.production.example
# Deploy guide: docs/DEMO_DEPLOYMENT_GUIDE.md

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

MATCH_THRESHOLD=0.75
MATCH_DEBUG=false
AI_MATCHING_MODE=hybrid
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

HF_API_KEY=
HF_CLIP_MODEL=openai/clip-vit-base-patch32
ENABLE_IMAGE_MATCHING=true
TEXT_MATCH_WEIGHT=0.4
IMAGE_MATCH_WEIGHT=0.4
LOCATION_MATCH_WEIGHT=0.2
LOCATION_MAX_KM=25

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REDIS_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Findora <noreply@findora.app>
